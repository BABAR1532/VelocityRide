# Copy this file to .env and fill in your values
# cp .env.example .env

# JWT
JWT_SECRET=velocity_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=velocity_refresh_secret_key_change_in_production

# MongoDB (used by docker-compose; individual services override)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=password
